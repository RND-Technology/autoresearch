# LIV HANA SI — autoresearch environment config
# Copy to .env and fill in real values. NEVER commit .env to git.

# DSPy Brain Cloud Run URL
DSPY_BRAIN_URL=https://dspy-brain-plad5efvha-uc.a.run.app

# Integration Service URL
INTEGRATION_SERVICE_URL=https://integration-service-plad5efvha-uc.a.run.app

# Path to experiment log
EXPERIMENT_LOG_PATH=./experiments_log.jsonl

# Max wall-clock minutes per experiment (hard ceiling)
MAX_EXPERIMENT_MINUTES=5

# Enable safety gate (recommended: true)
SAFETY_GATE_ENABLED=true

# Agent identifier for experiment log
AGENT_NAME=codex
